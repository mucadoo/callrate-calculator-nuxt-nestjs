generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model AreaCode {
  id               Int           @id @default(autoincrement())
  code             String        @unique
  originRates      CallingRate[] @relation("OriginArea")
  destinationRates CallingRate[] @relation("DestinationArea")

  @@map("area_code")
}

model CallingPlan {
  id                     Int    @id @default(autoincrement())
  name                   String
  minutes                Int
  exceededMinutesPercent Float

  @@map("calling_plan")
}

model CallingRate {
  id                Int   @id @default(autoincrement())
  originAreaId      Int
  destinationAreaId Int
  ratePerMin        Float

  originArea      AreaCode @relation("OriginArea", fields: [originAreaId], references: [id])
  destinationArea AreaCode @relation("DestinationArea", fields: [destinationAreaId], references: [id])

  @@map("calling_rate")
}
