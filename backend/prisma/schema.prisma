generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Country {
  id        Int           @id @default(autoincrement())
  name      String
  phoneCode String        @unique
  rates     CallingRate[]

  @@map("country")
}

model Provider {
  id           Int           @id @default(autoincrement())
  name         String
  callingRates CallingRate[]
  callingPlans CallingPlan[]

  @@map("provider")
}

model CallingPlan {
  id                     Int       @id @default(autoincrement())
  name                   String
  minutes                Int
  exceededMinutesPercent Float
  providerId             Int?
  provider               Provider? @relation(fields: [providerId], references: [id])

  @@map("calling_plan")
}

model CallingRate {
  id                Int       @id @default(autoincrement())
  destinationCountryId Int
  providerId        Int?
  ratePerMin        Float

  destinationCountry Country   @relation(fields: [destinationCountryId], references: [id])
  provider           Provider? @relation(fields: [providerId], references: [id])

  @@map("calling_rate")
}
