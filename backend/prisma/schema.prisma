generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Country {
  id        Int           @id @default(autoincrement())
  name      String
  phoneCode String        @unique
  rates     CallingRate[]

  @@map("country")
}

model Provider {
  id           Int           @id @default(autoincrement())
  name         String
  callingPlans CallingPlan[]

  @@map("provider")
}

model CallingPlan {
  id                     Int           @id @default(autoincrement())
  name                   String
  minutes                Int
  exceededMinutesPercent Float
  providerId             Int?
  provider               Provider?     @relation(fields: [providerId], references: [id])
  rates                  CallingRate[]

  @@map("calling_plan")
}

model CallingRate {
  id                   Int         @id @default(autoincrement())
  destinationCountryId Int
  planId               Int
  ratePerMin           Float

  destinationCountry   Country     @relation(fields: [destinationCountryId], references: [id])
  plan                 CallingPlan @relation(fields: [planId], references: [id])

  @@map("calling_rate")
}
