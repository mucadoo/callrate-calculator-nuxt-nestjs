{
  "openapi": "3.0.0",
  "info": {
    "title": "vxtel",
    "version": "v1"
  },
  "servers": [
    {
      "description": "Local server",
      "url": "/api"
    }
  ],
  "paths": {
    "/ddd": {
      "get": {
        "operationId": "listDDDs",
        "tags": [
          "DDD"
        ],
        "responses": {
          "200": {
            "description": "List of all ddds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/DDD"
                  }
                }
              }
            }
          }
        }
      },
      "/ddd/{id}": {
        "get": {
          "operationId": "showDDD",
          "tags": [
            "DDD"
          ],
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "description": "Id of ddd to show",
              "required": true,
              "type": "integer",
              "format": "int64"
            }
          ],
          "responses": {
            "200": {
              "description": "Return ddd with given id",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/DDD"
                  }
                }
              }
            },
            "404": {
              "description": "DDD not found",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/NotFoundError"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/callingPlan": {
      "/callingPlan/{id}": {
        "get": {
          "operationId": "showCallingPlan",
          "tags": [
            "CallingPlan"
          ],
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "description": "Id of Calling Plan to show",
              "required": true,
              "type": "integer",
              "format": "int64"
            }
          ],
          "responses": {
            "200": {
              "description": "Return Calling Plan with given id",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/DDD"
                  }
                }
              }
            },
            "404": {
              "description": "Calling Plan not found",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/NotFoundError"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/callingRate": {
      "/callingRate/{id}": {
        "get": {
          "operationId": "showCallingRate",
          "tags": [
            "CallingRate"
          ],
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "description": "Id of Calling Rate to show",
              "required": true,
              "type": "integer",
              "format": "int64"
            }
          ],
          "responses": {
            "200": {
              "description": "Return Calling Rate with given id",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/CallingRate"
                  }
                }
              }
            },
            "404": {
              "description": "Calling Rate not found",
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/NotFoundError"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "DDD": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NewDDD"
          },
          {
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64"
              }
            }
          }
        ]
      },
      "CallingPlan": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NewCallingPlan"
          },
          {
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64"
              }
            }
          }
        ]
      },
      "CallingRate": {
        "allOf": [
          {
            "$ref": "#/components/schemas/NewCallingRate"
          },
          {
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "format": "int64"
              }
            }
          }
        ]
      },
      "ValidationError": {
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "ValidationError"
            ]
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationErrorDetail"
            }
          }
        }
      },
      "ValidationErrorDetail": {
        "properties": {
          "message": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        }
      },
      "NotFoundError": {
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "NotFoundError"
            ]
          },
          "details": {
            "type": "string",
            "enum": [
              "DDD with id {id} not found"
            ]
          }
        }
      }
    }
  }
}
